{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Promoter or Supervisor).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["promoter", "supervisor"] },
        "supervisorId": { "type": "string", "description": "ID of the supervisor (if role is promoter)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Catalog of products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "barcode"]
    },
    "ExpirationRecord": {
      "title": "ExpirationRecord",
      "description": "Record of a product's expiration date and stock.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "storeId": { "type": "string" },
        "promoterId": { "type": "string" },
        "expirationDate": { "type": "string", "format": "date" },
        "quantity": { "type": "number" },
        "dailyGiro": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["SAFE", "WARNING", "CRITICAL"] },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "storeId", "promoterId", "expirationDate", "quantity", "dailyGiro", "riskLevel"]
    },
    "Form": {
      "title": "Form",
      "description": "Dynamic form created by a supervisor.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["checklist", "rupture"] },
        "createdBy": { "type": "string", "description": "Supervisor ID" },
        "questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "createdBy", "questions"]
    },
    "FormResponse": {
      "title": "FormResponse",
      "description": "Response to a form by a promoter.",
      "type": "object",
      "properties": {
        "formId": { "type": "string" },
        "promoterId": { "type": "string" },
        "storeId": { "type": "string" },
        "answers": { "type": "object" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["formId", "promoterId", "storeId", "answers"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores the product catalog."
    },
    "expirations/{expirationId}": {
      "schema": { "$ref": "#/entities/ExpirationRecord" },
      "description": "Stores expiration records submitted by promoters."
    },
    "forms/{formId}": {
      "schema": { "$ref": "#/entities/Form" },
      "description": "Stores forms created by supervisors."
    },
    "formResponses/{responseId}": {
      "schema": { "$ref": "#/entities/FormResponse" },
      "description": "Stores responses to forms."
    }
  }
}
